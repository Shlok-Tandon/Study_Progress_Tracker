rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Public profile: name, streak, xp, badges, etc. ----
    match /users/{profileId} {
      allow read: if request.auth != null;

      // Brand-new profile (this name has never been claimed before).
      allow create: if request.auth != null;

      allow update: if request.auth != null && (
        // Owner: your uid is already in the profile's authUids.
        request.auth.uid in resource.data.authUids

        // Claiming an existing profile from a new session: only
        // authUids/updatedAt may change, your own uid must be the one
        // being added, and you must have already proven you know the
        // PIN (see /unlocks/{uid} below) — that proof is what actually
        // gates this branch.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUids', 'updatedAt'])
          && request.auth.uid in request.resource.data.authUids
          && exists(/databases/$(database)/documents/users/$(profileId)/unlocks/$(request.auth.uid))
        )
      );

      // ---- The PIN itself. Nobody can ever read this from the app —
      // only via the Firebase Console (which bypasses these rules
      // entirely), so you can view or manually reset a PIN as an admin
      // without any user ever being able to see one. ----
      match /private/auth {
        allow read: if false;

        // Set once, at first signup, when the profile doc doesn't exist yet.
        allow create: if request.auth != null;

        // Let an already-authorized owner change their own PIN later
        // (e.g. a "change PIN" option in Settings, if you add one).
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/users/$(profileId)).data.authUids;

        allow delete: if false;
      }

      // ---- Proof that a claiming device knows the PIN. Also never
      // client-readable — its only purpose is to let the update rule
      // above check exists(), it's not meant to be read back. ----
      match /unlocks/{uid} {
        allow read: if false;
        allow write: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.pin == get(/databases/$(database)/documents/users/$(profileId)/private/auth).data.pin;
      }
    }

    match /tasks/{taskId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.assignedToUid)).data.authUids;
    }
  }
}
