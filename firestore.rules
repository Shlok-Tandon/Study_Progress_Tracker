rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{profileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      allow update: if request.auth != null && (
        // Owner: your uid is already in the profile's authUids.
        request.auth.uid in resource.data.authUids
        // Self-claim: adding only yourself to authUids (same name, new session).
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUids', 'updatedAt'])
            && request.auth.uid in request.resource.data.authUids)
        // Kudos: anyone may bump only the kudosReceived field.
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kudosReceived'])
      );
    }

    match /tasks/{taskId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(resource.data.assignedToUid)).data.authUids;
    }
  }
}